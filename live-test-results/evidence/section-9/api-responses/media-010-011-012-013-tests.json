{
  "MEDIA-010": {
    "test_id": "MEDIA-010",
    "description": "Speculative command rewrite detection",
    "cases": [
      {
        "transcription": "help command",
        "formatted_message": "!help",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "explicit help intent"
      },
      {
        "transcription": "show me the help",
        "formatted_message": "!help",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "show-me-help intent"
      },
      {
        "transcription": "what commands are available",
        "formatted_message": "!help",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "what-commands intent"
      },
      {
        "transcription": "run skill transcribe",
        "formatted_message": "!skill transcribe",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "explicit skill intent"
      },
      {
        "transcription": "use the skill something",
        "formatted_message": "!skill something",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "use-skill intent"
      },
      {
        "transcription": "Can you explain how things work?",
        "formatted_message": "!help",
        "expected_speculative": true,
        "actual_speculative": true,
        "passed": true,
        "label": "speculative help rewrite"
      },
      {
        "transcription": "Can you explain skills?",
        "formatted_message": "!skill",
        "expected_speculative": true,
        "actual_speculative": true,
        "passed": true,
        "label": "speculative skill rewrite"
      },
      {
        "transcription": "hello world",
        "formatted_message": "hello world",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "no command prefix"
      },
      {
        "transcription": "talk to research",
        "formatted_message": "@research tell me about AI",
        "expected_speculative": false,
        "actual_speculative": false,
        "passed": true,
        "label": "mention not command"
      }
    ],
    "all_passed": true
  },
  "MEDIA-011": {
    "test_id": "MEDIA-011",
    "description": "Unavailable agent mention sanitization",
    "cases": [
      {
        "input": "@code hello",
        "output": "@code hello",
        "passed": true,
        "label": "available agent keeps @"
      },
      {
        "input": "@research hello",
        "output": "research hello",
        "passed": true,
        "label": "unavailable configured agent loses @"
      },
      {
        "input": "@unknown hello",
        "output": "@unknown hello",
        "passed": true,
        "label": "unknown entity keeps @"
      },
      {
        "input": "@code @research @vision hi",
        "output": "@code research vision hi",
        "passed": true,
        "label": "mixed mentions"
      }
    ],
    "all_passed": true
  },
