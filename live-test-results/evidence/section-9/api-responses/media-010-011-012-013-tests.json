  "MEDIA-013": {
    "test_id": "MEDIA-013",
    "description": "Router echo dedup and permission denial",
    "checks": {
      "no_echo_initially": true,
      "echo_stored_after_mark": true,
      "echo_dedup_on_second_call": true
    },
    "code_references": {
      "echo_guard": "bot.py:1126 - checks agent_name != ROUTER and config.voice.visible_router_echo",
      "permission_guard": "bot.py:1064 - _precheck_event enforces sender authorization before voice processing"
    },
    "all_passed": true
  }
}
